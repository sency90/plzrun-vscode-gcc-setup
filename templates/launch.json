{
    // plzrun-vscode-gcc-setup — F5 디버깅 (debug 빌드 사용)
    //   디버거 OS 자동분기: Linux/WSL=gdb, macOS=lldb
    //   필요 확장: ms-vscode.cpptools (install.sh 가 자동 설치)
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (F5, pgm_debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/pgm_debug",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "preLaunchTask": "build debug (-std=c++14 -g)",
            "MIMode": "gdb",
            "linux": {
                "MIMode": "gdb",
                "miDebuggerPath": "/usr/bin/gdb"
            },
            "osx": {
                "MIMode": "lldb"
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
